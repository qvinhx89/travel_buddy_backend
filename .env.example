# Local development only. Copy this file to `.env`.
# For Render, set these variables in the Render Dashboard instead of committing a file.

NODE_ENV=development
PORT=3000

# Local MySQL:
# DATABASE_URL=mysql://user:password@localhost:3306/travel_buddy
# TiDB Cloud:
DATABASE_URL=mysql://user:password@gateway01.region.prod.aws.tidbcloud.com:4000/travel_buddy?sslaccept=strict

JWT_ACCESS_SECRET=replace_with_a_long_random_secret_at_least_16_chars
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret_at_least_16_chars
JWT_REFRESH_EXPIRES_IN=30d
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
CORS_ORIGIN=*

# Render free/ephemeral disks lose uploaded track files on redeploy/restart.
# Use a persistent disk mounted at UPLOAD_DIR, or replace this with S3-compatible storage.
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
